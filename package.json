{
  "name": "realtime-voice-infra",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade transport layer for voice agents.",
  "license": "MIT",
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "yarn workspaces foreach -Apt run build",
    "test": "yarn workspaces foreach -Apt run test",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "yarn workspaces foreach -Apt run typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.9.5",
    "typescript": "^5.4.5",
    "vitest": "^3.2.7"
  },
  "resolutions": {
    "fast-uri": "^3.1.2",
    "hono": "^4.12.25",
    "node-gyp/undici": "^6.27.0",
    "sigstore": "^4.1.1",
    "ws": "^8.21.0"
  }
}
