PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# REQUIRED: at least 32 bytes. Replace before deploying.
JWT_SECRET=replace-me-with-at-least-32-random-bytes-xx

# Optional. If unset, stream-server uses an in-memory session store.
REDIS_URL=redis://localhost:6379

# Backpressure thresholds (bytes). See .context/backpressure.md.
BACKPRESSURE_THRESHOLD=262144
BACKPRESSURE_RESUME=65536

SHUTDOWN_GRACE_MS=10000

# OpenTelemetry OTLP endpoint (see docker-compose observability profile).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
